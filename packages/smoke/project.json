{
  "name": "smoke",
  "root": "packages/smoke",
  "targets": {
    "verify": {
      "executor": "nx:run-commands",
      "cache": true,
      "dependsOn": [{"projects": "safedep-cli", "target": "build-dev"}],
      "options": {
        "command": "node packages/cli/dist/bin.cjs version",
        "cwd": "{workspaceRoot}"
      },
      "inputs": [
        "{workspaceRoot}/packages/cli/dist/bin.cjs",
        "{workspaceRoot}/packages/cli-linux-x64/bin/safedep",
        "{workspaceRoot}/packages/cli-linux-arm64/bin/safedep",
        "{workspaceRoot}/packages/cli-darwin-x64/bin/safedep",
        "{workspaceRoot}/packages/cli-darwin-arm64/bin/safedep",
        "{workspaceRoot}/packages/cli-win32-x64/bin/safedep.exe"
      ]
    }
  }
}
