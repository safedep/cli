{
  "name": "@safedep/cli",
  "root": "packages/cli",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "cache": true,
      "dependsOn": [{"projects": "sync-binaries", "target": "run"}],
      "options": {
        "command": "pnpm run build",
        "cwd": "{projectRoot}"
      },
      "inputs": [
        "{projectRoot}/src/**",
        "{projectRoot}/tsdown.config.ts",
        "{projectRoot}/tsconfig.json"
      ],
      "outputs": ["{projectRoot}/dist"]
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm run typecheck",
        "cwd": "{projectRoot}"
      },
      "inputs": [
        "{projectRoot}/src/**",
        "{projectRoot}/tsconfig.json"
      ]
    }
  }
}
