{
  "name": "safedep-cli",
  "root": ".",
  "targets": {
    "build-snapshot": {
      "executor": "nx:run-commands",
      "options": {
        "command": "goreleaser build --clean --snapshot",
        "cwd": "{workspaceRoot}"
      },
      "inputs": ["goWorkspaceSources"],
      "outputs": ["{workspaceRoot}/dist"]
    },
    "build-dev": {
      "executor": "nx:noop",
      "dependsOn": [{"projects": "@safedep/cli", "target": "build"}]
    },
    "verify": {
      "executor": "nx:noop",
      "dependsOn": [{"projects": "smoke", "target": "verify"}]
    }
  }
}
